// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom MVP fields for GitRekt
  university    String?
  course        String?
  skills        String[]  @default([])
  interests     String[]  @default([])
  swipes        Swipe[]   @relation("ActorSwipes")
  receivedSwipes Swipe[]  @relation("TargetSwipes")
  teams         TeamMember[]
  sentMessages  ChatMessage[] @relation("SentMessages")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  skillsNeeded String[] @default([])
  members     TeamMember[]
  swipes      Swipe[]  @relation("TeamSwipes")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id     String @id @default(cuid())
  userId String
  teamId String
  role   String @default("MEMBER") // e.g., "LEAD", "MEMBER"
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Swipe {
  id         String   @id @default(cuid())
  actorId    String   // The User swiping
  targetUserId String? // The User being swiped on
  targetTeamId String? // The Team being swiped on
  targetType String   // "USER" or "TEAM"
  direction  String   // "LIKE" or "PASS"
  createdAt  DateTime @default(now())

  actor      User     @relation("ActorSwipes", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser User?    @relation("TargetSwipes", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetTeam Team?    @relation("TeamSwipes", fields: [targetTeamId], references: [id], onDelete: Cascade)

  @@unique([actorId, targetUserId, targetTeamId])
}

model Event {
  id          String   @id @default(cuid())
  name        String
  description String?
  date        DateTime
  location    String?
  url         String?
  createdAt   DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  chatId    String   // e.g., "user1_user2"
  senderId  String
  content   String
  createdAt DateTime @default(now())

  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}
